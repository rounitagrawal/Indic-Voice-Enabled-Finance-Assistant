# ── Indic Finance Assistant — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# ── Gemini LLM ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI4Bharat / ULCA (Shabdh Tech) ───────────────────────────────────────────
ULCA_API_KEY=your_ulca_api_key_here
ULCA_USER_ID=your_ulca_user_id_here
ULCA_AUTHORIZATION=your_ulca_authorization_token_here

# ── App ───────────────────────────────────────────────────────────────────────
# Set to "production" in prod, "development" locally
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=5003

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_PATH=data/finance_qa.csv
FAISS_INDEX_PATH=data/faiss_index.bin

# ── Model ─────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=paraphrase-MiniLM-L6-v2
TOP_K_RETRIEVAL=4
